```gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so
*.pyd

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*
!.env.example

# PyCharm
.idea/
*.iml

# VS Code
.vscode/

# pytest
.pytest_cache/

# mypy
.mypy_cache/

# Ruff
.ruff_cache/

# Pyre
.pyre/

# Coverage
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Type checker caches
.pytype/

# Build artifacts
*.spec

# Local SQLite databases
*.sqlite3
*.db
```
